# =============================================================================
# Greenhouse SaaS - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.

# Django
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_SETTINGS_MODULE=config.settings.development
# Edge mode: True for Raspberry Pi / LoRa local deployment, False for cloud SaaS (default).
EDGE_MODE=False

# Database
POSTGRES_DB=greenhouse
POSTGRES_USER=greenhouse
POSTGRES_PASSWORD=greenhouse_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# MQTT
MQTT_BROKER_HOST=mosquitto
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# LoRa Bridge
LORA_SERIAL_PORT=/dev/ttyUSB0
LORA_SERIAL_BAUDRATE=115200

# Frontend
VITE_API_URL=http://localhost:8000/api
VITE_WS_URL=ws://localhost:8000/ws
# Set to "true" for Raspberry Pi / LoRa edge deployments (shows MQTT, LoRa Bridge menu items)
# Set to "false" (or omit) for cloud/SaaS deployments (shows CRM, Sync menu items)
VITE_EDGE_MODE=false
# VITE_BACKEND_URL is used by the Vite dev server proxy (not the browser).
# In Docker: http://backend:8000 — locally: http://localhost:8000 (default)
# VITE_BACKEND_URL=http://backend:8000

# JWT
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Sentry (optional — leave empty to disable)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
VITE_SENTRY_DSN=

# Grafana (production monitoring)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=greenhouse
GRAFANA_ROOT_URL=http://localhost:3000

# Backup
BACKUP_RETENTION_DAYS=30

# Stripe Billing (Sprint 22)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...
FRONTEND_URL=http://localhost:5173
